{
  "name": "localdrop-pc",
  "version": "1.1.9",
  "description": "Cross-platform file sharing",
  "author": "devtphbs",
  "private": true,
  "main": "main.js",
  "repository": "https://github.com/devtphbs/localdrop-pc",
  "scripts": {
    "build": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.localdrop.pc",
    "productName": "LocalDrop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "devtphbs",
      "repo": "localdrop-pc",
      "releaseType": "release"
    }
  }
}
