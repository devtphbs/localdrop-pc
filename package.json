{
  "name": "localdrop-pc",
  "version": "1.0.8",
  "description": "Cross-platform file sharing",
  "author": "devtphbs",
  "private": true,
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/devtphbs/localdrop-pc.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish always"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.localdrop.pc",
    "productName": "LocalDrop",
    "files": [
      "main.js",
      "index.html",
      "icon.ico",
      "icon.png",
      "icon.icns",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "devtphbs",
      "repo": "localdrop-pc"
    }
  }
}
